<footer class="contact-footer">
  <div class="footer-inner-wrapper">
    <div class="contact-info-grid-3col">

      <!-- Column 1: Company Info -->
      <div class="contact-info-box company-box">
        {% if page.lang == "th" %}
          <h2 class="contact-info-title">{{ site.company.name_th | default: "บริษัท อมตะ โปรดักชั่น จำกัด" }}</h2>
          <p class="contact-info-item">
              <a href="https://maps.app.goo.gl/46SZnCwHuesWyBwm7" target="_blank" aria-label="View on Google Maps">
                {% include icons/location-dot-solid.liquid %}
              </a>
            สำนักงานใหญ่: {{ site.company.address_th | default: "110/2 ถนนสามชัย ตำบลหาดใหญ่ อำเภอหาดใหญ่ สงขลา 90110" }}
          </p>
          <p class="contact-info-item">
            {% include icons/id-card-solid.liquid %}
            <a href="{{ site.company.vcard_url | default: 'https://vcard-admin.pkp.homes/U0NtnOPAOx' }}" target="_blank">นามบัตรดิจิทอล</a>
          </p>
        {% else %}
          <h2 class="contact-info-title">{{ site.company.name | default: "Amata Production Co., Ltd." }}</h2>
          <p class="contact-info-item">
              <a href="https://maps.app.goo.gl/46SZnCwHuesWyBwm7" target="_blank" aria-label="View on Google Maps">
                {% include icons/location-dot-solid.liquid %}
              </a>
            Head Office: {{ site.company.address | default: "110/2 Samchai Road, Hat Yai Subdistrict, Hat Yai District, Songkhla 90110" }}
          </p>
          <p class="contact-info-item">
            {% include icons/id-card-solid.liquid %}
            <a href="{{ site.company.vcard_url | default: 'https://vcard-admin.pkp.homes/U0NtnOPAOx' }}" target="_blank">Digital Card</a>
          </p>
        {% endif %}
      </div>

      <!-- Divider -->
      <div class="contact-info-divider"></div>

      <!-- Column 2: Contact -->
      <div class="contact-info-box contact-box">
        <div class="contact-info-item">{% include icons/phone-solid.liquid %}<a href="tel:{{ site.company.phone | default: '0818888866' | remove: '-' }}">{{ site.company.phone | default: "081-888-8866" }}</a></div>
        <div class="contact-info-item">{% include icons/line-brands.liquid %}<a href="https://line.me/ti/p/{{ site.company.line | default: '@amatapr' | remove: '@' }}" target="_blank">{{ site.company.line | default: "@amatapr" }}</a></div>
        <div class="contact-info-item">{% include icons/email-solid.liquid %}<a href="mailto:{{ site.company.email | default: 'sales@amataproduction.com' }}">{{ site.company.email | default: "bluroca.info@gmail.com }}</a></div>
        <div class="contact-info-item">{% include icons/world.liquid %}<a href="https://{{ site.company.website | default: 'www.bluroca.com' }}" target="_blank">{{ site.company.website | default: "www.bluroca.com" }}</a></div>
      </div>

      <!-- Divider -->
      <div class="contact-info-divider"></div>

      <!-- Column 3: Social Media -->
      <div class="contact-info-box social-box">
        {% if site.company.social %}
          {% for social in site.company.social %}
            <div class="contact-info-item">
              {% include icons/{{ social.icon | default: 'social-brands' }}.liquid %}
              <a href="{{ social.url }}" target="_blank">{{ social.name }}</a>
            </div>
          {% endfor %}
        {% else %}
          <div class="contact-info-item">{% include icons/facebook-brands.liquid %}<a href="https://www.facebook.com/amataproduction" target="_blank">AMATA Production</a></div>
          <div class="contact-info-item">{% include icons/facebook-brands.liquid %}<a href="https://www.facebook.com/amataproduction.polo" target="_blank">AMATA Polo</a></div>
          <div class="contact-info-item">{% include icons/facebook-brands.liquid %}<a href="https://www.facebook.com/amataproduction.sport" target="_blank">AMATA Sport</a></div>
          <div class="contact-info-item">{% include icons/instagram-brands.liquid %}<a href="https://www.instagram.com/amata.production/" target="_blank">amata.production</a></div>
        {% endif %}
      </div>

    </div>
  </div>
</footer>

<style>
.contact-footer {
  width: 100%;
  background-color: var(--global-nav-color);
  color: var(--global-text-nav-color);
  padding: 2.5rem 1rem;
  min-height: 300px;
  contain: layout;
}

.footer-inner-wrapper {
  max-width: 1300px;
  margin: 0 auto;
  width: 100%;
}

.contact-info-grid-3col {
  display: grid;
  grid-template-columns: 32% 1px 32% 1px 32%;
  gap: 2rem;
  align-items: flex-start;
}

.contact-info-box {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-info-title {
  font-size: clamp(1.05rem, 1.5vw, 1.3rem);
  font-weight: 600;
  margin: 0;
  color: var(--global-text-nav-color);
}

.contact-info-item {
  display: flex;
  align-items: flex-start;
  font-size: clamp(0.9rem, 1.3vw, 1.05rem);
  line-height: 1.6;
  color: var(--global-text-nav-color);
}

.contact-info-item svg {
  width: 24px;
  height: 24px;
  margin-right: 0.6rem;
  flex-shrink: 0;
  fill: var(--global-text-nav-color);
}

.contact-info-item svg[stroke="currentColor"] {
  fill: none;
  stroke: var(--global-text-nav-color);
}

.contact-info-item a {
  color: var(--global-text-nav-color);
  text-decoration: none;
  font-weight: 400;
  word-break: break-word;
  transition: color 0.2s ease;
}

.contact-info-item a:hover {
  color: var(--global-hover-nav-color);
}

.contact-info-divider {
  background-color: var(--global-text-color);
  width: 1px;
  height: 100%;
}

@media (max-width: 768px) {
  .contact-footer {
    min-height: 500px;
  }
  
  .contact-info-grid-3col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info-divider {
    height: 1px;
    width: 100%;
  }
}
</style>